# ============================================================
# Alexandria — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# Ne jamais committer .env.local
# ============================================================

# ------------------------------------------------------------
# Supabase (obligatoire — app Next.js + script Python)
# Où trouver : Dashboard Supabase → Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key

# ------------------------------------------------------------
# OpenAI (obligatoire — génération des réponses RAG)
# Modèle utilisé : gpt-4o-mini
# IMPORTANT : uniquement des caractères ASCII imprimables
# ------------------------------------------------------------
OPENAI_API_KEY=sk-proj-...

# ------------------------------------------------------------
# Sécurité des routes cron
# Protège GET /api/cron/retention et GET /api/cron/veille
# Valeur libre, à définir aussi dans Vercel > Environment Variables
# ------------------------------------------------------------
CRON_SECRET=votre-secret-local

# ------------------------------------------------------------
# Pipeline veille — limites (optionnel, valeurs par défaut si absent)
# ------------------------------------------------------------
VEILLE_MAX_URLS_PER_RUN=50
VEILLE_MAX_URLS_PER_SOURCE=30

# ------------------------------------------------------------
# LLM alternatif (non utilisé en production)
# ------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
